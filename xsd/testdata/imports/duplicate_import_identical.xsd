<?xml version="1.0" encoding="UTF-8"?>
<!--
  Two <xs:import> elements that are byte-identical: same namespace, same
  schemaLocation. Dedupe should collapse them to a single load.
-->
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           targetNamespace="http://example.com/duplicate-identical">

    <xs:import namespace="http://example.com/foreign" schemaLocation="foreign.xsd"/>
    <xs:import namespace="http://example.com/foreign" schemaLocation="foreign.xsd"/>

    <xs:element name="Root" type="xs:string"/>
</xs:schema>
